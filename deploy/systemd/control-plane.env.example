OPENCLAW_API_LISTEN_ADDR=:8080
OPENCLAW_DATABASE_URL=postgres://openclaw:openclaw@127.0.0.1:5432/openclaw_autodeploy?sslmode=disable
OPENCLAW_RUNTIME_WORKSPACE_ROOT=/srv/openclaw/tenants
OPENCLAW_RUNTIME_DOCKER_NETWORK=traefik-public
OPENCLAW_RUNTIME_BOOTSTRAP_MOUNT_PATH=/bootstrap
OPENCLAW_RUNTIME_DATA_MOUNT_PATH=/data
OPENCLAW_RUNTIME_BASE_DOMAIN=example.com
OPENCLAW_RUNTIME_HEALTH_POLL_INTERVAL=3s
OPENCLAW_RUNTIME_HEALTH_TIMEOUT=60s
OPENCLAW_SECURITY_MASTER_KEY=replace-with-32-byte-secret
OPENCLAW_WORKER_NAME=ultraworker
OPENCLAW_WORKER_POLL_INTERVAL=15s
OPENCLAW_WORKER_HEARTBEAT_TTL=45s
